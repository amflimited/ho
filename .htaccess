
# hoosier-online-security-v051 -- BEGIN
# Block direct web access to internal credentials, packages, database seeds, logs, and manifests.
<FilesMatch "^(database|database\.local|database\.local\.example|admin-secrets|admin-secrets\.example)\.php$">
  Require all denied
</FilesMatch>

<FilesMatch "^(deploy-manifest\.json|README_INSTALL\.txt|SECURITY_NOTES\.txt)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(sql|zip|log|env|ini|bak)$">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^go/([a-z0-9_-]+)/?$ go.php?slug=$1 [L,QSA]
  RewriteRule ^(db|uploads)/ - [F,L]
</IfModule>

Options -Indexes
# hoosier-online-security-v051 -- END


# V052 hardening: deny direct access to private/sensitive runtime artifacts
<FilesMatch "(^\.|database\.local|admin-secrets|\.sql$|\.log$|\.zip$|composer\.(json|lock)|package(-lock)?\.json)">
  Require all denied
</FilesMatch>

RedirectMatch 404 ^/(db|private|backups?|logs?|uploads?)/

Options -Indexes
